//@version=6
indicator("Golden/Grey Ribbon [8/20 SMA + RSI Internal Band]", shorttitle="GGR-RSI", overlay=true)

// ── Inputs ──────────────────────────────────────────────
grpMA = "Ribbon (SMA)"
fastLen = input.int(8, "Fast SMA Length", minval=1, group=grpMA)
slowLen = input.int(20, "Slow SMA Length", minval=1, group=grpMA)

grpRSI = "RSI Internal Band"
rsiTF      = input.timeframe("", "RSI Timeframe", group=grpRSI, tooltip="Blank = chart timeframe (no HTF call, zero lag). Set to any timeframe, e.g. 60, 240, D, W.")
rsiSrc     = input.source(close, "RSI Source", group=grpRSI)
rsiLen     = input.int(14, "RSI Length", minval=1, group=grpRSI)
bandLen    = input.int(20, "Band Length (SMA/StDev of RSI)", minval=1, group=grpRSI)
bandMult   = input.float(1.0, "Band Multiplier (StDev)", minval=0.1, step=0.1, group=grpRSI)
showInner  = input.bool(true, "Show Inner Band", group=grpRSI)
insetPct   = input.float(15, "Inner Band Inset %", minval=0, maxval=45, group=grpRSI, tooltip="How far the inner band sits inside the outer ribbon's edges.")
minHalfATR = input.float(0.1, "Inner Band Min Half-Width (x ATR)", minval=0, step=0.05, group=grpRSI, tooltip="Floors the inner band half-width so the momentum read stays legible when the ribbon pinches at crosses.\n0 = pure geometric mapping (band collapses to a point at crosses).\nNote: near crosses a floored band will poke slightly outside the outer ribbon.")

grpState = "State Logic"
useRsiConfirm   = input.bool(true, "Tier ±2: RSI agrees with ribbon (RSI vs band basis)", group=grpState)
useThrustTier   = input.bool(true, "Tier ±3: RSI thrust beyond band", group=grpState, tooltip="Upgrades the state when RSI closes outside its band in the trend direction (thrust vs drift). Gives Band Multiplier a role in the state logic.")
useStrengthGate = input.bool(true, "Gate: ribbon width >= threshold, else state = 0 (chop)", group=grpState, tooltip="Defines real neutrality: if |fast - slow| in ATR multiples is below the threshold, exported state is 0 regardless of direction.\nVisual ribbon colouring is unaffected (always raw direction).")
widthThresh     = input.float(0.5, "Width Threshold (ATR multiples)", minval=0, step=0.1, group=grpState, tooltip="Calibrate empirically per ticker/TF using the 'Ribbon Width (ATR mult)' data-window export.")
atrLen          = input.int(14, "ATR Length (normalisation)", minval=1, group=grpState)
nonRepaint      = input.bool(true, "Non-repainting (confirm on bar close / HTF-safe RSI)", group=grpState)

grpStyle = "Style"
colBull = input.color(#D4AF37, "Bull - Gold", group=grpStyle)
colBear = input.color(#787B86, "Bear - Grey", group=grpStyle)
showBg  = input.bool(false, "Background highlight (strong states only)", group=grpStyle)

// ── Ribbon SMAs ─────────────────────────────────────────
smaFast = ta.sma(close, fastLen)
smaSlow = ta.sma(close, slowLen)
atrVal  = ta.atr(atrLen)

// ── RSI + band, computed on the RSI timeframe ────────────
// FIX: basis/stdev are computed INSIDE the security call so bandLen counts
// HTF bars, not chart bars of a step series. (Chart-TF stdev of an HTF step
// series is systematically depressed and made bandMult timeframe-dependent.)
rsiExpr   = ta.rsi(rsiSrc, rsiLen)
basisExpr = ta.sma(rsiExpr, bandLen)
devExpr   = ta.stdev(rsiExpr, bandLen)

[rsiSafe, basisSafe, devSafe] = request.security(syminfo.tickerid, rsiTF, [rsiExpr[1], basisExpr[1], devExpr[1]], lookahead=barmerge.lookahead_on)
[rsiLive, basisLive, devLive] = request.security(syminfo.tickerid, rsiTF, [rsiExpr, basisExpr, devExpr], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

useHtf   = rsiTF != ""
rsiRaw   = not useHtf ? rsiExpr   : nonRepaint ? rsiSafe   : rsiLive
rsiBasis = not useHtf ? basisExpr : nonRepaint ? basisSafe : basisLive
rsiDev   = (not useHtf ? devExpr  : nonRepaint ? devSafe   : devLive) * bandMult

rsiUpper = math.min(rsiBasis + rsiDev, 100)
rsiLower = math.max(rsiBasis - rsiDev, 0)

// ── Map the RSI band into the outer ribbon's price range ───
ribbonHigh = math.max(smaFast, smaSlow)
ribbonLow  = math.min(smaFast, smaSlow)
ribbonMid  = (ribbonHigh + ribbonLow) / 2
ribbonHalf = math.max((ribbonHigh - ribbonLow) / 2 * (1 - insetPct / 100), minHalfATR * atrVal)

innerBasis = ribbonMid + ribbonHalf * ((rsiBasis - 50) / 50)
innerUpper = ribbonMid + ribbonHalf * ((rsiUpper - 50) / 50)
innerLower = ribbonMid + ribbonHalf * ((rsiLower - 50) / 50)

// ── State ───────────────────────────────────────────────
// Tier ladder: 0 = chop (width gate) | ±1 = direction | ±2 = +RSI agreement | ±3 = +RSI band thrust
// (Thrust implies agreement since upper >= basis >= lower, so the ladder is monotone.)
maState     = smaFast > smaSlow ? 1 : smaFast < smaSlow ? -1 : 0
rsiState    = rsiRaw > rsiBasis ? 1 : rsiRaw < rsiBasis ? -1 : 0
thrustState = rsiRaw > rsiUpper ? 1 : rsiRaw < rsiLower ? -1 : 0

ribbonWidthN = (smaFast - smaSlow) / atrVal   // signed, ATR-normalised trend strength
widthOK      = not useStrengthGate or math.abs(ribbonWidthN) >= widthThresh

int rawState = 0
if maState != 0 and widthOK
    int tier = 1
    if useRsiConfirm and rsiState == maState
        tier := 2
    if useThrustTier and thrustState == maState
        tier := 3
    rawState := maState * tier

// Confirmed state + freshness. barsSinceFlip resets on any sign change of the
// confirmed state, including into/out of 0 — so with the gate on, "fresh regime"
// fires when a trend *establishes* (width clears threshold), not at the raw cross.
var int confirmedState = 0
var int barsSinceFlip  = 0
if barstate.isconfirmed
    int prevSign = confirmedState > 0 ? 1 : confirmedState < 0 ? -1 : 0
    confirmedState := rawState
    int newSign = confirmedState > 0 ? 1 : confirmedState < 0 ? -1 : 0
    barsSinceFlip := newSign != prevSign ? 0 : barsSinceFlip + 1

plotState = nonRepaint ? confirmedState : rawState

outerColor = maState == 1 ? colBull : maState == -1 ? colBear : color.new(color.gray, 50)
innerColor = rsiState == 1 ? colBull : rsiState == -1 ? colBear : color.new(color.gray, 50)

// ── Plots: Outer ribbon ─────────────────────────────────
pFast = plot(smaFast, "SMA Fast", color=outerColor, linewidth=2)
pSlow = plot(smaSlow, "SMA Slow", color=color.new(color.gray, 35), linewidth=1)
fill(pFast, pSlow, color=color.new(outerColor, 75), title="Outer Ribbon Fill")

// ── Plots: Inner band (RSI, mapped into price space) ────────
pInU = plot(showInner ? innerUpper : na, "Inner Band Upper", color=color.new(innerColor, 35), linewidth=1)
pInL = plot(showInner ? innerLower : na, "Inner Band Lower", color=color.new(innerColor, 35), linewidth=1)
plot(showInner ? innerBasis : na, "Inner Band Basis", color=color.new(innerColor, 10), linewidth=1)
fill(pInU, pInL, color=color.new(innerColor, thrustState != 0 ? 40 : 55), title="Inner Band Fill")

bgcolor(showBg and math.abs(plotState) >= 2 ? color.new(plotState > 0 ? colBull : colBear, 90) : na)

// ── Cross markers ────────────────────────────────────────
bullCrossRaw = ta.crossover(smaFast, smaSlow)
bearCrossRaw = ta.crossunder(smaFast, smaSlow)
bullCross = nonRepaint ? (bullCrossRaw and barstate.isconfirmed) : bullCrossRaw
bearCross = nonRepaint ? (bearCrossRaw and barstate.isconfirmed) : bearCrossRaw

plotshape(bullCross, title="Bull Cross", style=shape.triangleup, location=location.belowbar, color=colBull, size=size.tiny)
plotshape(bearCross, title="Bear Cross", style=shape.triangledown, location=location.abovebar, color=colBear, size=size.tiny)

// ── Alerts ───────────────────────────────────────────────
strongBullEnter = plotState >= 2 and plotState[1] < 2
strongBearEnter = plotState <= -2 and plotState[1] > -2
thrustBullEnter = plotState == 3 and plotState[1] != 3
thrustBearEnter = plotState == -3 and plotState[1] != -3

alertcondition(bullCross, title="Ribbon Bull Cross", message="GGR {{ticker}} {{interval}}: fast SMA crossed above slow SMA")
alertcondition(bearCross, title="Ribbon Bear Cross", message="GGR {{ticker}} {{interval}}: fast SMA crossed below slow SMA")
alertcondition(strongBullEnter, title="State Entered Strong Bull (>= +2)", message="GGR {{ticker}} {{interval}}: state entered strong bull (>= +2)")
alertcondition(strongBearEnter, title="State Entered Strong Bear (<= -2)", message="GGR {{ticker}} {{interval}}: state entered strong bear (<= -2)")
alertcondition(thrustBullEnter, title="State Entered Bull Thrust (+3)", message="GGR {{ticker}} {{interval}}: state entered +3 (RSI thrust)")
alertcondition(thrustBearEnter, title="State Entered Bear Thrust (-3)", message="GGR {{ticker}} {{interval}}: state entered -3 (RSI thrust)")

// ── Debug / stacking / screener outputs ───────────────────
plot(plotState, "Ribbon State (-3..+3)", display=display.data_window)
plot(barsSinceFlip, "Bars Since Flip (confirmed)", display=display.data_window)
plot(ribbonWidthN, "Ribbon Width (ATR mult, signed)", display=display.data_window)
plot(rsiRaw, "RSI (raw)", display=display.data_window)
plot(rsiUpper - rsiLower, "RSI Band Width", display=display.data_window)
plot(maState == rsiState ? 1 : 0, "MA/RSI Agreement", display=display.data_window)
