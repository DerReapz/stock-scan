# Copy to .env and fill in the keys for the providers you use.
# yfinance needs no key and is the default provider.

# Alpaca (https://alpaca.markets) — free key gives IEX data, paid subscription unlocks feed=sip
ALPACA_KEY_ID=
ALPACA_SECRET=

# Polygon.io (https://polygon.io) — free tier is 15-min delayed, 5 requests/min
POLYGON_API_KEY=
